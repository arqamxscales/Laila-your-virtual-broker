# ============================================================================
# GENZ PSX BROKER - ENVIRONMENT VARIABLES EXAMPLE
# ============================================================================
# Copy this file to .env.local for local development or set these variables
# in your deployment platform (Vercel, Netlify, etc).
#
# SECURITY: NEVER commit actual .env files to Git. This example contains only
# safe default values and demonstrates the required structure.
#
# Vercel/Netlify: Add these variables to your deployment dashboard under
# "Environment Variables" before deploying.
# ============================================================================

# ============================================================================
# AUTHENTICATION & DEMO USER
# ============================================================================
# Demo login credentials used when external auth is unavailable.
# These are visible in code and browser - for demo/testing only.
VITE_DEMO_EMAIL=demo@genzfintech.com
VITE_DEMO_PASSWORD=ChangeMe@2026

# ============================================================================
# AI & ANALYTICS CONFIGURATION
# ============================================================================
# Alert threshold for watchlist notifications (% change)
VITE_ALERT_THRESHOLD=2.5

# VGI AI Model version identifier
VITE_MODEL_VERSION=VGI-PSX-2.6

# ============================================================================
# OPTIONAL: EXTERNAL INTEGRATIONS
# ============================================================================
# Uncomment and configure these if adding external services.

# VITE_API_GDELT_ENDPOINT=https://api.gdeltproject.org
# VITE_API_PSX_ENDPOINT=https://dps.psx.com.pk

# Analytics/Monitoring (if adding external monitoring)
# VITE_ANALYTICS_KEY=your_analytics_key_here

# ============================================================================
# NOTES
# ============================================================================
# - All VITE_ prefixed variables are exposed to browser (safe public data)
# - Do NOT add secrets, API keys, or private credentials here
# - The app gracefully falls back to demo mode if external APIs are unavailable
# - Review README.md for full feature list and local development setup
